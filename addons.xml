		<import addon="xbmc.gui" version="5.17.0"/>
		<import addon="script.skinshortcuts" version="1.1.3"/>
		<import addon="script.image.resource.select" version="3.0.2"/>
		<import addon="script.module.pvr.artwork" version="2.0.0"/>
	</requires>
