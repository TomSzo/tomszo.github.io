- Hozzáadva: repository.elementumorg
- Hozzáadva: repository.jurialmunkey
- Hozzáadva: repository.movieshark
- Hozzáadva: repository.streamshark
        </news>
        <platform>all</platform>
        <license>GNU GENERAL PUBLIC LICENSE Version 3</license>
        <source>https://github.com/TomSzo/tomszo.github.io</source>
    </extension>
</addon>

