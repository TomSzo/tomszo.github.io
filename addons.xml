<addon id="service.autosub" name="AutoSub" version="1.0.1" provider-name="fnord12">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="default.py" start="login"/>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Auto Subtitle Enabler</summary>
        <description lang="en">Sets subtitle track according to your language preferences</description>
        <platform>all</platform>
    </extension>
</addon>

